# MySQL 연결 정보
spring.datasource.url=jdbc:mysql://localhost:3306/DB이름?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8&createDatabaseIfNotExist=true
spring.datasource.username=DB_사용자
spring.datasource.password=DB_비밀번호
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# Gemini API
gemini.api.key=GEMINI_API_KEY
gemini.api.url=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent